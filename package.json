{
  "name": "wsagent",
  "publisher": "Tenna",
  "displayName": "wsagent",
  "description": "agent for seed labs",
  "version": "0.0.2",
  "engines": {
    "vscode": "^1.118.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "enabledApiProposals": [
    "defaultChatParticipant"
  ],
  "contributes": {
    "chatParticipants": [
      {
        "id": "wsagent.myagent",
        "name": "WSAgent",
        "description": "你遇到了什么困难?"
      }
    ],
    "configuration": {
      "title": "WSAgent Settings",
      "properties": {
        "wsagent.apiKey": {
          "type": "string",
          "description": "DeepSeek API Key"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "pnpm run build",
    "compile": "tsc -p ./",
    "build": "esbuild ./src/extension.ts --bundle --outfile=out/extension.js --external:vscode --format=cjs --platform=node",
    "watch": "tsc -watch -p ./",
    "pretest": "pnpm run compile && pnpm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.118.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.9.1",
    "esbuild": "^0.28.0",
    "eslint": "^9.39.3",
    "mocha": "^11.7.5",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  },
  "dependencies": {
    "dotenv": "^17.4.2",
    "openai": "^6.35.0"
  },
  "repository":"https://github.com/Hebown/wsagent"
}
